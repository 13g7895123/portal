# =========================================
# Portal - Git Ignore
# =========================================

# ============ Python ============
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ============ Node.js / Bun ============
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun-debug.log*
# npm lockfile (project uses bun)
package-lock.json

# ============ Build outputs ============
dist/
build/
.next/
out/

# ============ IDE ============
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============ OS ============
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============ Environment ============
.env
.env.local
.env.*.local
!.env.example
# docker/envs - 只保留 example，其他含機密資訊
docker/envs/.env.development
docker/envs/.env.production
docker/envs/.env.staging

# ============ 機密資料 ============
# 用戶資料（含雜湊密碼）
backend/users.json

# ============ Logs ============
logs/
*.log

# ============ Docker ============
# 不忽略 docker-compose 檔案
# 但忽略 docker 相關的暫存

# ============ Database ============
*.sqlite

# ============ 靜態上傳 ============
backend/static/uploads/*
!backend/static/uploads/.gitkeep
*.db

# ============ Coverage ============
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ============ Uploads ============
# 忽略上傳的檔案，但保留目錄結構
static/uploads/*
!static/uploads/.gitkeep
