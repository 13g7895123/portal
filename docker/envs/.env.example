# =========================================
# Portal - 環境設定範本
# =========================================
# 複製此檔案為 .env 並填入實際值

# Compose project name (replaces container_name)
COMPOSE_PROJECT_NAME=portal

# 外部埠號設定
NGINX_PORT=9110
BACKEND_PORT=9210
DB_EXTERNAL_PORT=9310

# 前端 API 設定 (給瀏覽器使用的外部 URL)
# 開發環境範例: http://localhost:9210
# 正式環境範例: https://api.your-domain.com
VITE_API_URL=http://localhost:9210

# 資料庫設定
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=portal_db
DB_PORT=5432

# 藍綠部署設定
# 當前活躍的前端環境 (blue 或 green)
ACTIVE_FRONTEND=blue

# pgAdmin 設定
# 登入 pgAdmin 介面使用的帳號（Email 格式）
PGADMIN_EMAIL=admin@example.com
# 登入 pgAdmin 介面使用的密碼
PGADMIN_PASSWORD=your_pgadmin_password
# 存取路徑：http://your-host/pgadmin/
# 注意：若 POSTGRES_USER 或 POSTGRES_DB 有異動，請同步更新 docker/pgadmin/servers.json
